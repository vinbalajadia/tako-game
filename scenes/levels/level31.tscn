[sub_resource type="Resource" id="Resource_tn66k"]
script = ExtResource("7_6rif1")
speaker_name = "ልነጋቻፏⶴፓኡረ ዓሠቹዪፕሃ፱ጎዐየ"
text = "Wait... your avatar... you look just like... No! You're the one the Universal Kernel sent to delete me! Stay back!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_6rif1"]
script = ExtResource("7_6rif1")
speaker_name = "ልነጋቻፏⶴፓኡረ ዓሠቹዪፕሃ፱ጎዐየ"
text = "I didn't mean to break the city! I just wanted to fix my Data Structures grade! I missed one semicolon, the arrays collapsed into each other, and now the whole simulation is crashing!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_n44fp"]
script = ExtResource("7_6rif1")
speaker_name = "ልነጋቻፏⶴፓኡረ ዓሠቹዪፕሃ፱ጎዐየ"
text = "Please, don't format my drive!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_0wrp3"]
script = ExtResource("7_6rif1")
speaker_name = "Alex"
text = "The matrix... it's stable. The red NullReference errors are gone."
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_gty5e"]
script = ExtResource("7_6rif1")
text = "(Alex looks at their hands, then up at the player)"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_lmkq1"]
script = ExtResource("7_6rif1")
speaker_name = "Alex"
text = "You didn't delete my code... you rewrote it. You extracted the data perfectly."
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_x2pnm"]
script = ExtResource("7_6rif1")
speaker_name = "Alex"
text = "I thought the system was broken beyond repair. I thought I was just fundamentally unable to understand it... but you showed me the logic. You didn't give up when it got hard. Thank you."
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_l8cw0"]
script = ExtResource("7_6rif1")
speaker_name = "Alex"
text = "But wait....."
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_twxnd"]
script = ExtResource("7_6rif1")
speaker_name = "Alex"
text = "..... Why are we still pixelated?"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_rsn2i"]
script = ExtResource("7_6rif1")
speaker_name = "Alex"
text = "Why are we still pixelated?"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

