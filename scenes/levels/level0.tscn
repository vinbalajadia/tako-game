[sub_resource type="Resource" id="Resource_ng1gw"]
script = ExtResource("7_1nvli")
text = "What?!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_yxkm4"]
script = ExtResource("7_1nvli")
text = "Where am I?!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_vals0"]
script = ExtResource("7_1nvli")
text = "What... what happened to the graphics? Why is my hand pixelated? Did the compiler just crash reality?!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_d3ub6"]
script = ExtResource("7_1nvli")
speaker_name = "ODIN"
text = "Do not panic. An unauthorized user has triggered a Null Reference Cascade. Manila's logic is broken. "
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_7s2gi"]
script = ExtResource("7_1nvli")
text = "HUH?! WHO ARE YOU?!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_3ebcg"]
script = ExtResource("7_1nvli")
speaker_name = "ODIN"
text = "I am ODIN. You are the Runtime Compiler. Fix the code, or the simulation crashes"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_luu1i"]
script = ExtResource("7_1nvli")
text = "That doesn't make sense."
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_db1u1"]
script = ExtResource("7_1nvli")
speaker_name = "ODIN"
text = "Don't worry. I'll guide you through everything. For now let's defeat some bugs!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_po5je"]
script = ExtResource("7_1nvli")
text = "Use WASD or Arrow Keys to move."
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_a76di"]
script = ExtResource("7_1nvli")
speaker_name = "The Silent Phantom"
text = "I am raising my hand to greet the simulation, but no words come out! My output stream is completely blank! How do I speak to the world?!"

[sub_resource type="Resource" id="Resource_oem7y"]
script = ExtResource("7_1nvli")
speaker_name = "The Heavy Allocator"
text = "I am trying to smash this identity into the system! I know my ID is a solid, whole number 404, but I don't have the memory allocated to hold something this heavy! Give me a variable!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_fj52k"]
script = ExtResource("7_1nvli")
speaker_name = "The Modulo Slasher"
text = "I can slice ten power cycles into three perfect pieces, but my blade cannot calculate what is left over! The remainder is driving me mad! Give me the right operator!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_1t5oo"]
script = ExtResource("7_1nvli")
speaker_name = "The Panicking Gatekeeper"
text = "Too much data! True? False? Are their access levels high enough?! The gates are open to everyone and my head is splitting! Build me a logic gate to filter them before I crash!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_m6lg1"]
script = ExtResource("7_1nvli")
speaker_name = "The Memory Mercenary"
text = "I need to load three security keys to breach the exit, but my belt only has single-variable pouches! I need a contiguous magazine! Give me a block of memory that holds exactly three!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_3asx1"]
script = ExtResource("7_1nvli")
text = "It doesn't work. I don't think any of them work."
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_mtrs4"]
script = ExtResource("7_1nvli")
text = "Just a pile of trash...."
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_rbahy"]
script = ExtResource("7_1nvli")
text = "Press E to interact. Try booting this computer."
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

