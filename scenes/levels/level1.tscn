[sub_resource type="Resource" id="Resource_8a7m2"]
script = ExtResource("7_2r1tl")
speaker_name = "The Null-Blade Vanguard"
text = "I have the weapons! I have the data! But the armory rack does not exist in the physical realm! I forgot to allocate the memory! Every sword I forge falls into the void!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_plydf"]
script = ExtResource("7_2r1tl")
speaker_name = "The Out-of-Bounds Evoker"
text = "The containment array holds five spells! One, two, three, four, five! So why does my matrix shatter when I try to thrust this flame into slot number five?!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_5ntmo"]
script = ExtResource("7_2r1tl")
speaker_name = "The Hardcoded Herald"
text = "My torch must process exactly ten embers! It has always been ten! I do not care if the shipment only gave us eight today, my loop will keep burning nothing until it hits ten!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_nkeig"]
script = ExtResource("7_2r1tl")
speaker_name = "The Type-Clashing Alchemist"
text = "Data is data! It does not matter if this shelf is strictly for numerical integer potions, I am forcing this string of alphabetical text into it! Transmute it before my flask explodes!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_nfihu"]
script = ExtResource("7_2r1tl")
speaker_name = "The Off-By-One Oracle"
text = "I must gather the total power of these floating nodes! But my mind cannot extract them! Help me write a loop to add the value of every single node to my total, or they will scatter forever!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

