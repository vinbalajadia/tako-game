[sub_resource type="Resource" id="Resource_hkuam"]
script = ExtResource("7_dj4wq")
speaker_name = "ODIN"
text = "Uh oh. Looks like there are more bugs here."
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_k0mew"]
script = ExtResource("7_dj4wq")
speaker_name = "The Infinite Striker"
text = "Punch! Punch! Punch! I am tenderizing order number one, but I forgot how to decrement the queue! My counter is missing! I am trapped in an infinite combo!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_b0vvs"]
script = ExtResource("7_dj4wq")
speaker_name = "The Absolute Severer"
text = "Order number four is out of stock?! Then I shall sever the entire batch! My blade knows only to break! Please, teach me how to safely continue to the next order before I destroy the whole shift!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_oyk6k"]
script = ExtResource("7_dj4wq")
speaker_name = "The Blind Behemoth"
text = "Me cook! Me smash patties on the grill! Wait... is the store even open?! I always execute my actions first and check the boolean rules later! I need a loop that matches my blind rage!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_gycjm"]
script = ExtResource("7_dj4wq")
speaker_name = "The Frenzied Slicer"
text = "I must slice the potatoes into fries! But where do I start?! What is my limit?! How many per strike?! My for loop parameters are completely shattered! I am slicing the void!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_8i1lk"]
script = ExtResource("7_dj4wq")
speaker_name = "The Nested Beast"
text = "Tables! Seats! Rows! Columns! My mind cannot process two dimensions at once! I wiped table one, but the inner loop is trapped in my claws! Build the nested architecture so I can reach the rest!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_f3b2k"]
script = ExtResource("7_dj4wq")
speaker_name = "The Nested Beast"
text = "Boss is in the pool club if you're looking for em."
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_b4tpv"]
script = ExtResource("7_dj4wq")
text = "You found the easter egg! If you're the first to find this, shout \"ODIN is the best!\" to claim your prize!"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

[sub_resource type="Resource" id="Resource_hgky1"]
script = ExtResource("7_dj4wq")
text = "Customers Only"
metadata/_custom_type_script = "uid://cb4nyolipk5xc"

